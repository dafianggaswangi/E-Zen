rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidSantri(data) {
      return data.id is string && data.id.size() <= 64 &&
             data.name is string && data.name.size() <= 200 &&
             data.className is string && data.className.size() <= 100 &&
             (!('roomName' in data) || data.roomName is string && data.roomName.size() <= 100) &&
             (!('guardianName' in data) || data.guardianName is string && data.guardianName.size() <= 200) &&
             (!('guardianPhone' in data) || data.guardianPhone is string && data.guardianPhone.size() <= 64) &&
             (!('isBlacklisted' in data) || data.isBlacklisted is bool) &&
             (!('blacklistReason' in data) || data.blacklistReason is string && data.blacklistReason.size() <= 500) &&
             (!('unblacklistedAt' in data) || data.unblacklistedAt is string && data.unblacklistedAt.size() <= 100);
    }

    function isValidPermission(data) {
      return data.id is string && data.id.size() <= 128 &&
             data.studentId is string && data.studentId.size() <= 64 &&
             data.studentName is string && data.studentName.size() <= 200 &&
             data.className is string && data.className.size() <= 150 &&
             (!('roomName' in data) || data.roomName is string && data.roomName.size() <= 150) &&
             (!('guardianName' in data) || data.guardianName is string && data.guardianName.size() <= 200) &&
             (!('guardianPhone' in data) || data.guardianPhone is string && data.guardianPhone.size() <= 64) &&
             data.leaveType is string && data.leaveType.size() <= 64 &&
             data.reason is string && data.reason.size() <= 2000 &&
             data.startDate is string && data.startDate.size() <= 64 &&
             data.endDate is string && data.endDate.size() <= 64 &&
             (!('returnTime' in data) || data.returnTime is string && data.returnTime.size() <= 64) &&
             data.status is string && (data.status == 'Pending' || data.status == 'Disetujui' || data.status == 'Ditolak' || data.status == 'Sedang Berjalan' || data.status == 'Kembali') &&
             data.createdAt is string && data.createdAt.size() <= 100 &&
             (!('returnedAt' in data) || data.returnedAt is string && data.returnedAt.size() <= 100) &&
             (!('notifiedAt' in data) || data.notifiedAt is string && data.notifiedAt.size() <= 100);
    }

    function isValidUstadz(data) {
      return data.username is string && data.username.size() <= 64 &&
             data.name is string && data.name.size() <= 200 &&
             data.passcode is string && data.passcode.size() <= 10;
    }

    function isValidSheetsConfig(data) {
      return data.syncEnabled is bool &&
             (!('sheetUrl' in data) || data.sheetUrl is string && data.sheetUrl.size() <= 500) &&
             (!('sheetId' in data) || data.sheetId is string && data.sheetId.size() <= 200) &&
             (!('apiKey' in data) || data.apiKey is string && data.apiKey.size() <= 200) &&
             (!('appsScriptUrl' in data) || data.appsScriptUrl is string && data.appsScriptUrl.size() <= 500) &&
             (!('whatsappGroupLink' in data) || data.whatsappGroupLink is string && data.whatsappGroupLink.size() <= 500) &&
             (!('useWhatsAppGroup' in data) || data.useWhatsAppGroup is bool) &&
             (!('satpamPhone' in data) || data.satpamPhone is string && data.satpamPhone.size() <= 64);
    }

    function isValidPrayerAttendance(data) {
      return data.date is string && data.date.size() <= 64 &&
             data.prayer is string && (data.prayer == 'Shubuh' || data.prayer == 'Dzuhur' || data.prayer == 'Ashar' || data.prayer == 'Maghrib' || data.prayer == 'Isya') &&
             data.updatedAt is string && data.updatedAt.size() <= 100 &&
             data.records is map;
    }

    // Rules for individual collections
    match /santri/{santriId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn() && isValidId(santriId) && isValidSantri(incoming());
      allow delete: if isSignedIn() && isValidId(santriId);
    }

    match /permissions/{permissionId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn() && isValidId(permissionId) && isValidPermission(incoming());
      allow delete: if isSignedIn() && isValidId(permissionId);
    }

    match /ustadz/{ustadzId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn() && isValidId(ustadzId) && isValidUstadz(incoming());
      allow delete: if isSignedIn() && isValidId(ustadzId);
    }

    match /sheetsConfig/{configId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn() && isValidId(configId) && isValidSheetsConfig(incoming());
      allow delete: if isSignedIn() && isValidId(configId);
    }

    match /prayerAttendance/{attendanceId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn() && isValidId(attendanceId) && isValidPrayerAttendance(incoming());
      allow delete: if isSignedIn() && isValidId(attendanceId);
    }
  }
}
